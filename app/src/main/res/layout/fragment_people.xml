<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    tools:context=".ui.people.PeopleFragment">

    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/people_empty"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnSurfaceVariant" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!--
            Proposition de fusion : une seule rangée. Comme un seul nom peut
            apparaître (la paire est toujours nommée + anonyme), la ligne EST la
            question — « Marie ? » — et le titre devient superflu. Les deux visages
            et les boutons oui/non suffisent à la poser.
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMerge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="6dp">

                <!--
                    La personne NOMMÉE d'abord, l'anonyme ensuite : on lit « est-ce
                    Marie ? » de gauche à droite, donc la référence connue vient en
                    premier. `layout_marginStart` (et non `Left`) suit la direction du
                    texte, l'ordre s'inversera donc de lui-même en écriture RTL.
                -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imageMergeKeep"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imageMergeOther"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="6dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/textMergeDetail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Marie ?" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonMergeDismiss"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/people_merge_suggest_dismiss"
                    app:icon="@drawable/vector_close"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonMergeConfirm"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/people_merge_suggest_confirm"
                    app:icon="@drawable/vector_check" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPeople"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="3" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabIdentify"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/people_to_identify"
        app:backgroundTint="?attr/colorPrimaryContainer"
        app:icon="@drawable/vector_peoples"
        app:iconTint="?attr/colorOnPrimaryContainer" />

</FrameLayout>