<?xml version="1.0" encoding="utf-8"?>
<!--
    Ordre : ce qu'on regarde (statistiques), ce qu'on règle tous les jours
    (affichage), ce qui alimente l'app (bibliothèque), ce qui la fait chercher
    (modèles), le réglage fin (avancé, en sous-écran), l'irréversible (isolé en
    dernier), puis À propos.

    La calibration vit dans debug_preferences.xml : six réglages de mise au point
    dont trois demandent de taper un décimal, ils n'ont rien à faire au même niveau
    que Thème et Langue.
-->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- STATISTIQUES DE LA BIBLIOTHÈQUE                                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_stats"
        app:title="@string/settings_category_stats">

        <com.cevague.vindex.ui.settings.StatsPreference
            app:iconSpaceReserved="false"
            app:key="stats_card"
            app:selectable="false" />

    </PreferenceCategory>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- AFFICHAGE                                                            -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_display"
        app:title="@string/settings_category_display">

        <ListPreference
            app:defaultValue="system"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:icon="@drawable/vector_palette"
            app:key="theme"
            app:title="@string/settings_theme"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            app:defaultValue="system"
            app:entries="@array/language_entries"
            app:entryValues="@array/language_values"
            app:icon="@drawable/vector_language"
            app:key="language"
            app:title="@string/settings_language"
            app:useSimpleSummaryProvider="true" />

        <SeekBarPreference
            android:max="6"
            app:defaultValue="3"
            app:icon="@drawable/vector_grid"
            app:key="grid_columns"
            app:min="2"
            app:showSeekBarValue="true"
            app:title="@string/settings_grid_columns" />

        <SwitchPreferenceCompat
            app:icon="@drawable/vector_peoples"
            app:key="show_hidden_people"
            app:summary="@string/settings_show_hidden_people_summary"
            app:title="@string/settings_show_hidden_people" />

    </PreferenceCategory>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- BIBLIOTHÈQUE                                                         -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_data"
        app:title="@string/settings_category_data">

        <Preference
            app:icon="@drawable/vector_folder"
            app:key="source_folders"
            app:summary="@string/settings_source_folder_summary"
            app:title="@string/settings_source_folder" />

        <Preference
            app:icon="@drawable/vector_refresh"
            app:key="rescan_gallery"
            app:summary="@string/settings_rescan_summary"
            app:title="@string/settings_rescan" />

    </PreferenceCategory>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- INTELLIGENCE ARTIFICIELLE                                            -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_ai"
        app:title="@string/settings_category_ai">

        <Preference
            app:icon="@drawable/vector_images_search"
            app:key="manage_models"
            app:summary="@string/settings_models_summary"
            app:title="@string/settings_models" />

        <Preference
            app:icon="@drawable/vector_percent"
            app:key="advanced_settings"
            app:summary="@string/settings_advanced_summary"
            app:title="@string/settings_advanced" />

    </PreferenceCategory>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- ZONE DANGEREUSE                                                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_danger"
        app:title="@string/settings_category_danger">

        <Preference
            app:icon="@drawable/vector_restore"
            app:key="reset_settings"
            app:summary="@string/settings_reset_summary"
            app:title="@string/settings_reset" />

        <Preference
            app:icon="@drawable/vector_delete_forever"
            app:key="reset_database"
            app:summary="@string/settings_reset_db_summary"
            app:title="@string/settings_reset_db" />

    </PreferenceCategory>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- À PROPOS                                                             -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:key="category_about"
        app:title="@string/settings_about">

        <Preference
            app:icon="@drawable/vector_info"
            app:key="app_version"
            app:selectable="false"
            app:summary=""
            app:title="@string/settings_version" />

        <Preference
            app:icon="@drawable/vector_code"
            app:key="source_code"
            app:summary="@string/settings_source_code_summary"
            app:title="@string/settings_source_code" />

        <Preference
            app:icon="@drawable/vector_license"
            app:key="license"
            app:summary="@string/settings_license_value"
            app:title="@string/settings_license" />

    </PreferenceCategory>

</PreferenceScreen>
